FROM python:3.14.3

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    ca-certificates \
    wget \
    tar \
    fontconfig \
    libpq-dev \
    pkg-config \
    gcc \
    postgresql-client \
    && rm -rf /var/lib/apt/lists/*

# Download and extract the appropriate Tectonic binary for the container CPU.
RUN ARCH=$(uname -m) && \
    if [ "$ARCH" = "aarch64" ]; then \
    wget -qO tectonic.tar.gz "https://github.com/tectonic-typesetting/tectonic/releases/download/tectonic%400.15.0/tectonic-0.15.0-aarch64-unknown-linux-musl.tar.gz" ; \
    else \
    wget -qO tectonic.tar.gz "https://github.com/tectonic-typesetting/tectonic/releases/download/tectonic%400.15.0/tectonic-0.15.0-x86_64-unknown-linux-musl.tar.gz" ; \
    fi && \
    tar -xzf tectonic.tar.gz && \
    mv tectonic /usr/local/bin/ && \
    rm tectonic.tar.gz

# Prime Tectonic's bundle cache so the first in-app compile is less likely to stall.
RUN printf '\\documentclass{article}\n\\begin{document}\nWarmup\n\\end{document}\n' > /tmp/tectonic-warmup.tex && \
    tectonic /tmp/tectonic-warmup.tex >/dev/null 2>&1 || true

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY . .

EXPOSE 8000

CMD ["sh", "-c", "until pg_isready -h db -U cheatsheet_user; do sleep 2; done && python manage.py migrate && python manage.py runserver 0.0.0.0:8000"]
